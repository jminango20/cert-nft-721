# Sepolia RPC endpoint (get one from Alchemy, Infura, or QuickNode)
SEPOLIA_RPC=

# Deployer private key — NEVER commit the real value
PRIVATE_KEY=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Optional: override the admin address at deploy time (defaults to deployer)
ADMIN_ADDRESS=

# Optional: set to any value to enable the gas reporter during tests
# REPORT_GAS=true
