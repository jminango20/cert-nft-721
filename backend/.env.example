RPC_URL=https://rpc.sepolia.org
PRIVATE_KEY=your_issuer_wallet_private_key
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PINATA_JWT=your_pinata_jwt_token
API_KEY=change-me-in-production
PORT=3001
FRONTEND_URL=http://localhost:3000
# Email delivery via SendGrid (https://sendgrid.com), single sender verified
# (no domain required). Optional — if not set, the claim-by-email flow logs
# a warning and skips sending; all other endpoints are unaffected.
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_verified_sender@example.com
# Postgres connection string (Supabase pooler recommended — see project Settings > Database > Connect)
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres"
