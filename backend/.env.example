RPC_URL=https://rpc.sepolia.org
PRIVATE_KEY=your_issuer_wallet_private_key
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PINATA_JWT=your_pinata_jwt_token
API_KEY=change-me-in-production
PORT=3001
FRONTEND_URL=http://localhost:3000
# Email delivery via Resend (https://resend.com). Optional — if not set,
# the claim-by-email flow logs a warning and skips sending; all other
# endpoints are unaffected.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=educert@yourdomain.com
# SQLite database path (relative to backend/ directory)
DATABASE_URL="file:./educert.db"
