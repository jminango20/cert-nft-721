generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Certificate {
  id             Int       @id @default(autoincrement())
  tokenId        Int       @unique
  txHash         String
  recipientName  String
  recipientEmail String?
  courseTitle    String
  issuedAt       DateTime  @default(now())
  revokedAt      DateTime?
  claimToken     String?   @unique
  claimExpiresAt DateTime?
  claimedAt      DateTime?
  claimedBy      String?
  ipfsCid        String
  ownerAddress   String?
}

model Claim {
  token             String    @id
  recipientName     String
  courseTitle       String
  courseId          String
  studentIdHash     String
  issueDate         String
  ects              Float
  eqfLevel          Int
  assessmentType    String
  participationMode String
  learningOutcomes  String
  evidences         Json
  ipfsCid           String?
  walletAddress     String?
  claimed           Boolean   @default(false)
  tokenId           String?
  txHash            String?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
}

model TxIndexEntry {
  tokenId String @id
  txHash  String
}
